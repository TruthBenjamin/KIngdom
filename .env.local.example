# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_SITE_URL=https://your-production-domain.com

# Server-only Supabase secret key. Never expose this with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Espees hosted payment portal. Keep the API key server-only.
ESPEES_MODE=live
ESPEES_API_KEY=your_espees_api_key
ESPEES_MERCHANT_WALLET=your_espees_merchant_wallet_address
ESPEES_API_URL=https://api.espees.org
ESPEES_PAYMENT_URL=https://payment.espees.org
ESPEES_PRICE_MULTIPLIER=1

# Google OAuth (optional)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id

# Admin login
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com
NEXT_PUBLIC_ADMIN_PASSWORD=replace-with-admin-password
